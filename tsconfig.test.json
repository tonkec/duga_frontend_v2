{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/*"]
    },
    "types": ["jest", "@testing-library/jest-dom", "node"]
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx", "jest.setup.ts", "src/test/**/*.ts"]
}
